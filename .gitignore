# ============================================================
# RefugIA OS — .gitignore
# ============================================================

# --- Python ---
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.Python

# --- Dependencias de Node ---
node_modules/

# --- Base de datos vectorial generada (se reconstruye con: refugia index) ---
src/db/*
!src/db/.gitkeep

# --- Configuración generada por el instalador ---
.refugia-config.json

# --- Logs y temporales ---
*.log
.DS_Store
