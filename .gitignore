# ============================================================
# RefugIA OS — .gitignore
# ============================================================

# --- Python ---
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.Python

# --- Dependencias de Node ---
node_modules/

# --- Base de datos vectorial generada (se reconstruye con: refugia index) ---
src/db/*
!src/db/.gitkeep

# --- Configuración generada por el instalador ---
.refugia-config.json

# --- Artefactos de empaquetado npm ---
*.tgz

# --- Índice RAG generado para móvil (se regenera con exportar_rag.py) ---
mobile/www/assets/rag_index.json

# --- Capacitor: dependencias y plataformas nativas generadas ---
mobile/node_modules/
mobile/android/
mobile/ios/
mobile/www/index.html
mobile/www/sw.js
mobile/www/manifest.json
mobile/www/icons/

# --- App Android nativa (AI Studio): artefactos de build ---
mobile/android-app/.gradle/
mobile/android-app/build/
mobile/android-app/app/build/
mobile/android-app/.idea/
mobile/android-app/local.properties
mobile/android-app/.env
mobile/android-app/debug.keystore
mobile/android-app/.kotlin/
# El índice RAG de assets SÍ se versiona: lo necesita la compilación en CI.
# (mobile/android-app/app/src/main/assets/rag_index.json queda trackeado)

# --- Logs y temporales ---
*.log
.DS_Store
